<?xml version="1.0" encoding="Windows-1252"?>
<!-- LEGACY Informatica PowerCenter mapping to migrate (reference input).
     Logic (also summarized in instruction.md), one row per customer over COMPLETED orders:
       FIL_COMPLETED : status = 'completed'
       AGG_CUSTOMER  : group by CUSTOMER_ID
                         LIFETIME_AMOUNT = SUM(AMOUNT)      (decimal)
                         ORDER_COUNT     = COUNT(ORDER_ID)
       EXP_BAND      : VALUE_BAND = IIF(LIFETIME_AMOUNT >= 200, 'A', 'B')
     Target: FCT_CUSTOMER_ORDERS  (grain: one row per customer). -->
<POWERMART CREATION_DATE="01/01/2024 00:00:00" REPOSITORY_VERSION="188.97">
<REPOSITORY NAME="EDW_REPO" VERSION="188" CODEPAGE="MS1252" DATABASETYPE="Oracle">
<FOLDER NAME="EDW">
  <SOURCE BUSINESSNAME="" DATABASETYPE="Oracle" DBDNAME="SRC" NAME="ORDERS"/>
  <TARGET BUSINESSNAME="" DATABASETYPE="Oracle" NAME="FCT_CUSTOMER_ORDERS" DESCRIPTION="Customer order fact"/>
  <MAPPING DESCRIPTION="Customer order fact over completed orders" ISVALID="YES" NAME="m_FCT_CUSTOMER_ORDERS">
    <TRANSFORMATION NAME="SQ_ORDERS" TYPE="Source Qualifier"/>
    <TRANSFORMATION NAME="FIL_COMPLETED" TYPE="Filter">
      <TRANSFORMFIELD NAME="FILTERCONDITION" PORTTYPE="INPUT/OUTPUT" EXPRESSION="STATUS = 'completed'"/>
    </TRANSFORMATION>
    <TRANSFORMATION NAME="AGG_CUSTOMER" TYPE="Aggregator">
      <TABLEATTRIBUTE NAME="Group By" VALUE="CUSTOMER_ID"/>
      <TRANSFORMFIELD NAME="LIFETIME_AMOUNT" PORTTYPE="OUTPUT" EXPRESSION="SUM(AMOUNT)"/>
      <TRANSFORMFIELD NAME="ORDER_COUNT" PORTTYPE="OUTPUT" EXPRESSION="COUNT(ORDER_ID)"/>
    </TRANSFORMATION>
    <TRANSFORMATION NAME="EXP_BAND" TYPE="Expression">
      <TRANSFORMFIELD NAME="VALUE_BAND" PORTTYPE="OUTPUT" EXPRESSION="IIF(LIFETIME_AMOUNT &gt;= 200, 'A', 'B')"/>
    </TRANSFORMATION>
    <INSTANCE NAME="FCT_CUSTOMER_ORDERS" TYPE="TARGET"/>
  </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>
