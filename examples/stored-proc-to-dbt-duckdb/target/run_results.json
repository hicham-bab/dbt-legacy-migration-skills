{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.12", "generated_at": "2026-07-10T20:53:00.290951Z", "invocation_id": "b75da5e2-16e3-40b9-ae3a-792c11ae7199", "invocation_started_at": "2026-07-10T20:52:59.294773Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.167566Z", "completed_at": "2026-07-10T20:53:00.172557Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.172846Z", "completed_at": "2026-07-10T20:53:00.225288Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.05838489532470703, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.stored_proc_duckdb.mart_customer_ltv", "compiled": true, "compiled_code": "-- Migrated from legacy/sp_customer_ltv.sql: the procedural temp-table rebuild becomes a\n-- declarative model on ref() staging models. Same output, same grain (one row per customer).\nwith completed as (\n    select customer_id, amount\n    from \"dev\".\"main\".\"stg_orders\"\n    where status = 'completed'\n),\n\nfinal as (\n    select\n        customer_id,\n        cast(sum(amount) as decimal(18, 2)) as lifetime_value,\n        count(*)                            as order_count,\n        case when sum(amount) >= 150 then 'high' else 'low' end as ltv_segment\n    from completed\n    group by customer_id\n)\n\nselect * from final", "relation_name": "\"dev\".\"main\".\"mart_customer_ltv\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.228485Z", "completed_at": "2026-07-10T20:53:00.231688Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.231927Z", "completed_at": "2026-07-10T20:53:00.246990Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.01984119415283203, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.stored_proc_duckdb.accepted_values_mart_customer_ltv_ltv_segment__high__low.9244e2122f", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        ltv_segment as value_field,\n        count(*) as n_records\n\n    from \"dev\".\"main\".\"mart_customer_ltv\"\n    group by ltv_segment\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'high','low'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.249189Z", "completed_at": "2026-07-10T20:53:00.251592Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.251811Z", "completed_at": "2026-07-10T20:53:00.256665Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.008677959442138672, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.stored_proc_duckdb.assert_customer_ltv_parity", "compiled": true, "compiled_code": "-- PARITY GATE (singular test): the migrated mart must match the legacy proc output row-for-row.\n-- dbt fails the build if this returns any rows. This is the \"prove it's correct\" step, running\n-- for real on DuckDB \u2014 the legacy output is captured as the seed legacy_customer_ltv.\nwith dbt_model as (\n    select * from \"dev\".\"main\".\"mart_customer_ltv\"\n),\n\nlegacy as (\n    select * from \"dev\".\"main\".\"legacy_customer_ltv\"\n),\n\ncompared as (\n    select\n        coalesce(d.customer_id, l.customer_id) as customer_id,\n        case\n            when d.customer_id is null then 'missing_in_dbt'\n            when l.customer_id is null then 'missing_in_legacy'\n            when round(cast(d.lifetime_value as double), 2)\n               <> round(cast(l.lifetime_value as double), 2) then 'lifetime_value_mismatch'\n            when cast(d.order_count as integer) <> cast(l.order_count as integer) then 'order_count_mismatch'\n            when d.ltv_segment <> l.ltv_segment then 'segment_mismatch'\n        end as diff\n    from dbt_model d\n    full outer join legacy l on d.customer_id = l.customer_id\n)\n\nselect * from compared\nwhere diff is not null", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.258814Z", "completed_at": "2026-07-10T20:53:00.262674Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.262837Z", "completed_at": "2026-07-10T20:53:00.266522Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.008995771408081055, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.stored_proc_duckdb.not_null_mart_customer_ltv_customer_id.8a829db09b", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect customer_id\nfrom \"dev\".\"main\".\"mart_customer_ltv\"\nwhere customer_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.268698Z", "completed_at": "2026-07-10T20:53:00.271162Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.271378Z", "completed_at": "2026-07-10T20:53:00.276446Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.008971929550170898, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.stored_proc_duckdb.not_null_mart_customer_ltv_lifetime_value.ad6e0de923", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect lifetime_value\nfrom \"dev\".\"main\".\"mart_customer_ltv\"\nwhere lifetime_value is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-10T20:53:00.278469Z", "completed_at": "2026-07-10T20:53:00.282134Z"}, {"name": "execute", "started_at": "2026-07-10T20:53:00.282526Z", "completed_at": "2026-07-10T20:53:00.286923Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.009682893753051758, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.stored_proc_duckdb.unique_mart_customer_ltv_customer_id.f8ccb94859", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    customer_id as unique_field,\n    count(*) as n_records\n\nfrom \"dev\".\"main\".\"mart_customer_ltv\"\nwhere customer_id is not null\ngroup by customer_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}], "elapsed_time": 0.2228538990020752, "args": {"empty": false, "show": false, "require_resource_names_without_spaces": true, "source_freshness_run_project_hooks": true, "export_saved_queries": false, "exclude_resource_types": [], "require_unique_project_resource_names": false, "print": true, "strict_mode": false, "use_colors_file": true, "upload_to_artifacts_ingest_api": false, "defer": false, "favor_state": false, "vars": {}, "validate_macro_args": false, "require_ref_searches_node_package_before_root": false, "log_format_file": "debug", "require_all_warnings_handled_by_warn_error": false, "which": "build", "include_saved_query": false, "use_colors": true, "static_parser": true, "show_resource_report": false, "write_json": true, "log_path": "/Users/hichambabahmed/dbt-legacy-migration-skills/examples/stored-proc-to-dbt-duckdb/logs", "printer_width": 80, "skip_nodes_if_on_run_start_fails": false, "show_all_deprecations": false, "macro_debugging": false, "version_check": true, "resource_types": [], "state_modified_compare_more_unrendered_values": false, "project_dir": "/Users/hichambabahmed/dbt-legacy-migration-skills/examples/stored-proc-to-dbt-duckdb", "require_explicit_package_overrides_for_builtin_materializations": true, "profiles_dir": "/Users/hichambabahmed/dbt-legacy-migration-skills/examples/stored-proc-to-dbt-duckdb", "populate_cache": true, "sqlparse": {"MAX_GROUPING_DEPTH": null, "MAX_GROUPING_TOKENS": null}, "partial_parse": true, "log_level": "info", "require_generic_test_arguments_property": true, "warn_error_options": {"error": [], "warn": [], "silence": []}, "quiet": false, "require_batched_execution_for_custom_microbatch_strat